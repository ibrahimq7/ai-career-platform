{
  "name": "ai-career-platform",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "npm --prefix frontend run build",
    "start": "uvicorn --app-dir backend/project/resume_backend app.resume_parser.main:app --host 0.0.0.0 --port 8000",
    "start:single": "powershell -ExecutionPolicy Bypass -File scripts/start.ps1",
    "dev:api": "uvicorn --app-dir backend/project/resume_backend app.resume_parser.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:web": "npm --prefix frontend run dev",
    "verify": "npm --prefix frontend run build && python -m compileall backend/project/resume_backend/app"
  }
}
